# Database — Supabase Postgres connection string (session pooler, not the
# direct/IPv6-only host — see README). Falls back to local SQLite if unset.
DATABASE_URL=

# Supabase project URL — used to fetch their public JWKS to verify tokens
# the frontend obtains directly from Supabase's own Auth API. No secret
# key needed here: this project's tokens are ES256-signed (asymmetric).
SUPABASE_URL=

ENV=local

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173

# LLM provider selection
LLM_PROVIDER=gemini
LLM_FALLBACK_PROVIDER=groq

# Gemini (primary) — free tier: 15 RPM / 500 RPD (per key, per model).
# GOOGLE_API_KEY is the primary key; GOOGLE_API_KEYS_EXTRA is an optional
# comma-separated list of additional keys (e.g. a second free-tier Google
# account) — core/gemini_client.py rotates through all of them, on both the
# chat LLM below and the embedding matcher addition further down, whenever
# one hits a rate limit or is rejected outright. Safe to leave empty.
GOOGLE_API_KEY=
GOOGLE_API_KEYS_EXTRA=
GEMINI_TEXT_MODEL=gemini-3.1-flash-lite

# Groq (fallback) — free tier: 60 RPM / 1K RPD / 500K TPD. Only used once
# every Gemini key above is exhausted.
GROQ_API_KEY=
GROQ_TEXT_MODEL=qwen/qwen3-32b

# Matcher: embedding-based retrieval (Layer 1, additive to the existing
# exact/fuzzy keyword cascade — see agent/matcher.py). Off by default;
# requires running `python -m seed.embed_products` once to backfill
# product embeddings before it has anything to match against.
ENABLE_EMBEDDING_MATCH=false
EMBEDDING_MODEL=gemini-embedding-001
# Tried on the same key before rotating to the next key in
# GOOGLE_API_KEYS_EXTRA — a different model has its own quota bucket, so
# this is a free extra attempt before burning a key switch.
EMBEDDING_MODEL_FALLBACK=gemini-embedding-2

# Jina AI — primary embedding + reranking provider for the matcher's
# optional Layer 1 addition (EMBEDDING_PROVIDER=jina by default; set to
# "gemini" to use the fallback path above instead). Free tier: 100 requests
# and 100,000 tokens per minute. CC-BY-NC 4.0 licensed — non-commercial use.
JINA_API_KEY=

# SSLCommerz (payment gateway) — defaults below are SSLCommerz's own public
# sandbox demo-store credentials (a real, working test account — no
# merchant registration needed for sandbox use). Override with your own
# sandbox/live credentials for a real deployment.
SSLCOMMERZ_STORE_ID=testbox
SSLCOMMERZ_STORE_PASSWORD=qwerty
SSLCOMMERZ_API_URL=https://sandbox.sslcommerz.com/gwprocess/v4/api.php
SSLCOMMERZ_VALIDATION_URL=https://sandbox.sslcommerz.com/validator/api/validationserverAPI.php
# Must be reachable from SSLCommerz's servers in production (not localhost).
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
