# Database (defaults to local SQLite if unset; use Postgres in production)
DATABASE_URL=

# Auth
SECRET_KEY=changeme-generate-a-long-random-string-for-real-deployments
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ENV=local

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173

# LLM provider selection
LLM_PROVIDER=gemini
LLM_FALLBACK_PROVIDER=groq

# Gemini (primary) — free tier: 15 RPM / 500 RPD
GOOGLE_API_KEY=
GEMINI_TEXT_MODEL=gemini-3.1-flash-lite

# Groq (fallback) — free tier: 60 RPM / 1K RPD / 500K TPD
GROQ_API_KEY=
GROQ_TEXT_MODEL=qwen/qwen3-32b
